{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=nfe_api;Username=postgres;Password=121456;"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/nfe-api-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Jwt": {
    "SecretKey": "your-secret-key-min-32-characters-here",
    "Issuer": "nfe-api",
    "Audience": "nfe-api-clients",
    "ExpirationMinutes": 60
  },
  "Sefaz": {
    "Environment": "homologacao",
    "State": "GO",
    "CertificatePath": "./certificates/cert.pfx",
    "CertificatePassword": "",
    "TimeoutSeconds": 30,
    "RetryPolicy": {
      "MaxRetries": 3,
      "DelayMilliseconds": 1000
    }
  },
  "ZeusFiscal": {
    "CertificatePath": "./certificates/cert.pfx",
    "CertificatePassword": "",
    "EmitterCnpj": "00000000000000",
    "Environment": "homologacao",
    "TimeoutSeconds": 30,
    "RetryPolicy": {
      "MaxRetries": 3,
      "DelayMilliseconds": 1000
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:5000"
      }
    }
  }
}